# Copy this file to .env and fill only the values you need.

# llama.cpp OpenAI-compatible server
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_API_KEY=not-needed
LLM_MODEL=discord-qwen-local
LLM_TIMEOUT_SECONDS=120

# Local llama.cpp server launcher. Fill these in .env if you want to use `just llama-server`.
# Keep local model paths out of Git.
LLAMA_SERVER_PATH=example/path/to/llama-server.exe
LLAMA_MODEL_PATH=example/path/to/model.gguf
LLAMA_MODEL_ALIAS=discord-qwen-local
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8001
LLAMA_CTX_SIZE=8192
LLAMA_N_GPU_LAYERS=999

# Classification behavior
CLASSIFICATION_THRESHOLD=0.70
MAX_CONTEXT_MESSAGES=6

# Discord bot. Optional; keep unset until testing against a Discord test server.
# Never commit your real token.
# DISCORD_TOKEN=
# DISCORD_MOD_CHANNEL_ID=
# Reserved for future controlled tests. Keep false in this phase.
AUTO_DELETE=false
